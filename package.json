{
  "name": "escape-room-control-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "app": "powershell -ExecutionPolicy Bypass -File .\\launch-desktop.ps1",
    "build": "tsc --noEmit && vite build",
    "start": "powershell -ExecutionPolicy Bypass -File .\\launch-desktop.ps1",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0",
    "electron-packager": "^17.1.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.championtracker.escape-room",
    "productName": "Escape Room Control",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "electron-main.js",
      "electron-main.cjs",
      "electron-preload.cjs"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "sign": false
    }
  }
}
